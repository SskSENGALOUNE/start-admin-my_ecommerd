[Unit]
Description={{ app_name }} API (Bun/Hono)
After=network.target

[Service]
User={{ app_user }}
Group={{ app_group }}
WorkingDirectory={{ server_current }}/server
EnvironmentFile=/etc/{{ app_name }}.env
ExecStart=/root/.bun/bin/bun ./dist/main.js
Environment=NODE_ENV=production
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
