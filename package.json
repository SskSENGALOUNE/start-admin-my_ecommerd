    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.106.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.159.5",
    "@tanstack/router-devtools": "^1.159.5",
    "better-auth": "1.4.18",
    "browser-image-compression": "^2.0.2",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.28",
    "jose": "^6.2.3",
    "lucide-react": "^0.563.0",
    "nanoid": "^5.1.6",
    "pg": "^8.18.0",
    "pg-transactional-outbox": "^0.6.5",
    "pubnub": "^11.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-joyride": "^2.9.3",
    "react-qr-code": "^2.0.21",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6",
    "zod-form-data": "^3.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@types/bun": "^1.3.9",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0"
  },
  "name": "bun-react-template",
  "overrides": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "browser": {
    "pubnub": "./node_modules/pubnub/dist/web/pubnub.min.js"
  },
  "private": true,
  "scripts": {
    "build": "bun run build.ts",
    "build:all": "bun run build.ts && bun run compile && bun run compile:worker",
    "compile": "bun build src/server/main.ts --outdir ./out/server --target bun",
    "compile:worker": "bun build src/server/worker.ts --outdir ./out/worker --target bun",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:pull": "drizzle-kit pull",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "bun --hot index-dev.ts",
    "format": "biome format .",
    "lint": "biome check .",
    "rbac:sync": "bun run src/modules/roles/domain/scripts/sync.ts",
    "seed:colors": "bun run src/server/scripts/seed-colors.ts",
    "start": "NODE_ENV=production bun index.ts",
    "worker": "WORKER_PORT=3001 bun run src/server/worker.ts"
  },
  "type": "module",
  "version": "0.1.0"
}
